          "settings": {
            "tabs": [
              {
                "_id": "tab_fs",
                "tab_title": "FloorScore",
                "tab_content": "<div style=\"padding: 32px 0;\"><h3 style=\"font-family: Sora, sans-serif; font-size: 36px; font-weight: 300; margin-bottom: 16px; color: #121212;\">FloorScore\u00ae</h3><p style=\"font-family: DM Sans, sans-serif; font-size: 16px; font-weight: 300; line-height: 1.625; color: #6E6E6E; max-width: 640px; margin-bottom: 32px;\">The gold standard for indoor air quality certification in hard surface flooring. FloorScore tests finished flooring products against the strictest VOC emission limits.</p><div style=\"display: flex; gap: 48px; margin-bottom: 32px;\"><div style=\"border-left: 2px solid #0164DB; padding-left: 24px;\"><div style=\"font-family: Sora, sans-serif; font-size: 48px; font-weight: 300; color: #121212;\">1,800+</div><div class=\"rfci-label\" style=\"color: #9E9E9E; margin-top: 8px;\">Certified Products</div></div><div style=\"border-left: 2px solid #0164DB; padding-left: 24px;\"><div style=\"font-family: Sora, sans-serif; font-size: 48px; font-weight: 300; color: #121212;\">20+</div><div class=\"rfci-label\" style=\"color: #9E9E9E; margin-top: 8px;\">Years Trusted</div></div></div><a href=\"/sustainability/floorscore\" style=\"display: inline-flex; align-items: center; gap: 8px; padding: 14px 32px; background: #0164DB; color: white; text-decoration: none; font-family: DM Sans, sans-serif; font-size: 14px; font-weight: 600;\">Explore FloorScore <span>&rarr;</span></a></div>"
              },
              {
                "_id": "tab_as",
                "tab_title": "ASSURE",
                "tab_content": "<div style=\"padding: 32px 0;\"><h3 style=\"font-family: Sora, sans-serif; font-size: 36px; font-weight: 300; margin-bottom: 16px; color: #121212;\">ASSURE Certification</h3><p style=\"font-family: DM Sans, sans-serif; font-size: 16px; font-weight: 300; line-height: 1.625; color: #6E6E6E; max-width: 640px; margin-bottom: 32px;\">A comprehensive product safety certification that verifies resilient flooring meets stringent physical performance and chemical content requirements through independent laboratory testing.</p><div style=\"display: flex; gap: 48px; margin-bottom: 32px;\"><div style=\"border-left: 2px solid #0164DB; padding-left: 24px;\"><div style=\"font-family: Sora, sans-serif; font-size: 48px; font-weight: 300; color: #121212;\">100%</div><div class=\"rfci-label\" style=\"color: #9E9E9E; margin-top: 8px;\">Third-Party Verified</div></div><div style=\"border-left: 2px solid #0164DB; padding-left: 24px;\"><div style=\"font-family: Sora, sans-serif; font-size: 48px; font-weight: 300; color: #121212;\">15+</div><div class=\"rfci-label\" style=\"color: #9E9E9E; margin-top: 8px;\">Test Parameters</div></div></div><a href=\"/sustainability/assure\" style=\"display: inline-flex; align-items: center; gap: 8px; padding: 14px 32px; background: #0164DB; color: white; text-decoration: none; font-family: DM Sans, sans-serif; font-size: 14px; font-weight: 600;\">Explore ASSURE <span>&rarr;</span></a></div>"
              },
              {
                "_id": "tab_af",
                "tab_title": "AFFIRM",
                "tab_content": "<div style=\"padding: 32px 0;\"><h3 style=\"font-family: Sora, sans-serif; font-size: 36px; font-weight: 300; margin-bottom: 16px; color: #121212;\">AFFIRM Certification</h3><p style=\"font-family: DM Sans, sans-serif; font-size: 16px; font-weight: 300; line-height: 1.625; color: #6E6E6E; max-width: 640px; margin-bottom: 32px;\">Verifies that resilient flooring products are manufactured using responsible environmental practices and meet defined sustainability criteria throughout the production process.</p><div style=\"display: flex; gap: 48px; margin-bottom: 32px;\"><div style=\"border-left: 2px solid #0164DB; padding-left: 24px;\"><div style=\"font-family: Sora, sans-serif; font-size: 48px; font-weight: 300; color: #121212;\">360\u00b0</div><div class=\"rfci-label\" style=\"color: #9E9E9E; margin-top: 8px;\">Supply Chain Review</div></div></div><a href=\"/sustainability/affirm\" style=\"display: inline-flex; align-items: center; gap: 8px; padding: 14px 32px; background: #0164DB; color: white; text-decoration: none; font-family: DM Sans, sans-serif; font-size: 14px; font-weight: 600;\">Explore AFFIRM <span>&rarr;</span></a></div>"
              },
              {
                "_id": "tab_ep",
                "tab_title": "EPDs",
                "tab_content": "<div style=\"padding: 32px 0;\"><h3 style=\"font-family: Sora, sans-serif; font-size: 36px; font-weight: 300; margin-bottom: 16px; color: #121212;\">Environmental Product Declarations</h3><p style=\"font-family: DM Sans, sans-serif; font-size: 16px; font-weight: 300; line-height: 1.625; color: #6E6E6E; max-width: 640px; margin-bottom: 32px;\">Industry-wide and product-specific EPDs provide transparent, third-party verified environmental impact data covering the full life cycle of resilient flooring products.</p><div style=\"display: flex; gap: 48px; margin-bottom: 32px;\"><div style=\"border-left: 2px solid #0164DB; padding-left: 24px;\"><div style=\"font-family: Sora, sans-serif; font-size: 48px; font-weight: 300; color: #121212;\">50+</div><div class=\"rfci-label\" style=\"color: #9E9E9E; margin-top: 8px;\">Published EPDs</div></div></div><a href=\"/sustainability/epds\" style=\"display: inline-flex; align-items: center; gap: 8px; padding: 14px 32px; background: #0164DB; color: white; text-decoration: none; font-family: DM Sans, sans-serif; font-size: 14px; font-weight: 600;\">Explore EPDs <span>&rarr;</span></a></div>"
              }
            ],
