{
  "version": "0.4",
  "title": "RFCI - Navigation Header",
  "type": "header",
  "content": [
    {
      "id": "nav0001",
      "elType": "container",
      "settings": {
        "content_width": "boxed",
        "boxed_width": { "unit": "px", "size": 1280 },
        "background_color": "#FFFFFF",
        "flex_direction": "row",
        "justify_content": "space-between",
        "align_items": "center",
        "padding": { "unit": "px", "top": "16", "right": "48", "bottom": "16", "left": "48", "isLinked": false },
        "padding_mobile": { "unit": "px", "top": "12", "right": "16", "bottom": "12", "left": "16", "isLinked": false },
        "position": "fixed",
        "z_index": 100,
        "border_border": "solid",
        "border_width": { "unit": "px", "top": "0", "right": "0", "bottom": "1", "left": "0", "isLinked": false },
        "border_color": "rgba(0,0,0,0.05)"
      },
      "elements": [
        {
          "id": "nav0002",
          "elType": "widget",
          "widgetType": "image",
          "settings": {
            "image": { "url": "/wp-content/themes/rfci-child-theme/assets/rfci-logo.svg" },
            "image_size": "custom",
            "image_custom_dimension": { "width": 120, "height": 40 },
            "link": { "url": "/", "is_external": false }
          }
        },
        {
          "id": "nav0003",
          "elType": "widget",
          "widgetType": "html",
          "settings": {
            "html": "<!-- NOTE: For the mega-menu navigation, use one of these approaches:\n\n  OPTION A (Recommended): Install JetMenu or ElementsKit\n  - Recreate the Resources and Sustainability mega menus in Elementor\n\n  OPTION B: Use Astra Header Builder\n  - Create a standard dropdown menu in Appearance > Menus and assign it to the Primary menu location\n\n  Current menu structure:\n  - About (/about)\n  - Resources\n    - Why Resilient (/why-resilient)\n    - Flooring Types (/flooring)\n    - Inspiration Gallery (/inspiration)\n    - Educational Videos (/videos)\n    - Resources (/resources)\n    - FAQ (/faq)\n    - Ecomedes (external)\n  - Sustainability\n    - FloorScore (/certifications/floorscore)\n    - ASSURE (/certifications/assure)\n    - AFFIRM (/certifications/affirm)\n    - Environmental Product Declarations (/certifications/epd)\n  - Member Directory (/members)\n  - Contact (/contact)\n-->\n<nav style=\"display:flex; align-items:center; gap:32px; font-family: DM Sans, sans-serif; font-size:14px; font-weight:500;\">\n  <a href=\"/about\" style=\"color:#121212; text-decoration:none;\">About</a>\n  <a href=\"/resources\" style=\"color:#121212; text-decoration:none;\">Resources</a>\n  <a href=\"/certifications/floorscore\" style=\"color:#121212; text-decoration:none;\">Sustainability</a>\n  <a href=\"/members\" style=\"color:#121212; text-decoration:none;\">Member Directory</a>\n  <a href=\"/contact\" style=\"color:#121212; text-decoration:none;\">Contact</a>\n</nav>"
          }
        },
        {
          "id": "nav0004",
          "elType": "widget",
          "widgetType": "button",
          "settings": {
            "text": "Join RFCI",
            "link": { "url": "/contact", "is_external": false },
            "background_color": "#0164DB",
            "button_text_color": "#FFFFFF",
            "border_radius": { "unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": true },
            "typography_typography": "custom",
            "typography_font_family": "DM Sans",
            "typography_font_size": { "unit": "px", "size": 13 },
            "typography_font_weight": "600",
            "button_padding": { "unit": "px", "top": "10", "right": "24", "bottom": "10", "left": "24", "isLinked": false },
            "_css_classes": "rfci-btn-primary"
          }
        }
      ]
    }
  ]
}
